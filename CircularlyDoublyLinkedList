public class CircularlyDoublyLinkedList<E> {

    private static class Node<E> {
        private E element;
        private Node<E> prev;
        private Node<E> next;

        public Node(E e, Node<E> p, Node<E> n) {
            element = e;
            prev = p;
            next = n;
        }

        public E getElement() { return element; }
        public Node<E> getNext() { return next; }
        public Node<E> getPrev() { return prev; }

        public void setNext(Node<E> n) { next = n; }
        public void setPrev(Node<E> p) { prev = p; }
    }

    private Node<E> tail = null;
    private int size = 0;

    public int size() { return size; }
    public boolean isEmpty() { return size == 0; }

    public E first() {
        if (isEmpty()) return null;
        return tail.getNext().getElement();
    }

    public E last() {
        if (isEmpty()) return null;
        return tail.getElement();
    }

    public void addFirst(E e) {
        if (tail == null) {
            tail = new Node<>(e, null, null);
            tail.setNext(tail);
            tail.setPrev(tail);
        } else {
            Node<E> newest = new Node<>(e, tail, tail.getNext());
            tail.getNext().setPrev(newest);
            tail.setNext(newest);
        }
        size++;
    }

    public void addLast(E e) {
        addFirst(e);
        rotate();
    }

    public void rotate() {
        if (tail != null) tail = tail.getNext();
    }

    public void rotateBackward() {
        if (tail != null) tail = tail.getPrev();
    }

    public E removeFirst() {
        if (isEmpty()) return null;

        Node<E> head = tail.getNext();
        E removed = head.getElement();

        if (head == tail) tail = null;
        else {
            tail.setNext(head.getNext());
            head.getNext().setPrev(tail);
        }

        size--;
        return removed;
    }

    public E removeLast() {
        if (isEmpty()) return null;

        E removed = tail.getElement();

        if (tail.getNext() == tail) tail = null;
        else {
            Node<E> head = tail.getNext();
            tail.getPrev().setNext(head);
            head.setPrev(tail.getPrev());
            tail = tail.getPrev();
        }

        size--;
        return removed;
    }
}
